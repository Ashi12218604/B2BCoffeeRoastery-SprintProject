## .NET / C# gitignore

# Build output — these are HUGE and auto-generated
**/bin/
**/obj/

# Visual Studio files
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# NuGet packages — restored automatically on build
**/packages/
!**/packages/build/
*.nupkg
*.nuget.props
*.nuget.targets
project.lock.json
project.fragment.lock.json
artifacts/

# Rider IDE
.idea/
*.sln.iml

# VS Code
.vscode/

# Entity Framework migrations temp
*.dbmdl
*.jfm

# Test results
TestResults/
*.trx
*.coverage
*.coveragexml

# Publish output
**/publish/
**/PublishProfiles/

# Environment / secrets — NEVER commit these
appsettings.Development.json
appsettings.Production.json
secrets.json
*.pfx
*.p12

# Logs
*.log
logs/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Node (if any frontend later)
node_modules/
dist/